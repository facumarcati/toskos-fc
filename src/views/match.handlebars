<div class="page-header">
  <span class="eyebrow">Detalle del Partido</span>
  <h1>{{formatDate match.date}}</h1>
  {{#if match.venue}}
  <p class="page-header-meta">{{match.venue}}</p>
  {{/if}}
</div>

<div class="match-detail-card">

  <!-- Scoreboard -->
  <div class="match-detail-scoreboard">
    <div class="match-detail-team {{#if (eq winner "A")}}team-winner{{/if}}">
      <div class="match-detail-team-badge">B</div>
      <span class="match-detail-team-name">Blanco</span>
      {{#if (eq winner "A")}}<span class="match-detail-winner-badge">Ganador</span>{{/if}}
    </div>

    <div class="match-detail-score">
      <span class="match-detail-score-number">{{totalGoalsA}} — {{totalGoalsB}}</span>
    </div>

    <div class="match-detail-team match-detail-team-right {{#if (eq winner "B")}}team-winner{{/if}}">
      <div class="match-detail-team-badge">N</div>
      <span class="match-detail-team-name">Negro</span>
      {{#if (eq winner "B")}}<span class="match-detail-winner-badge">Ganador</span>{{/if}}
    </div>
  </div>

  {{#if match.youtubeUrl}}
  <div class="match-detail-video">
    <a href="{{match.youtubeUrl}}" target="_blank" rel="noopener noreferrer" class="btn-match-action btn-youtube">
      <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
      </svg>
      Ver video del partido
    </a>
  </div>
  {{/if}}

</div>

<!-- Players Grid -->
<div class="match-detail-sections">

  <!-- Equipo Blanco -->
  <div class="form-panel match-detail-team-panel">
    <div class="match-detail-team-header">
      <div class="match-detail-team-badge-lg">B</div>
      <span class="match-detail-team-label">Equipo Blanco</span>
      <span class="match-detail-team-goals">{{totalGoalsA}} goles</span>
    </div>

    <div class="match-detail-players">
      {{#each teamAPlayers}}
      <div class="match-detail-player-row">
        <div class="match-detail-player-info">
          <span class="match-detail-player-name {{#if this.guest}}player-guest{{/if}}">
            {{this.player.name}}
            {{#if this.guest}}<span class="guest-tag">Invitado</span>{{/if}}
          </span>
        </div>
        <div class="match-detail-player-stats">
          <span class="match-detail-stat {{#if (gt this.goals 0)}}stat-active{{/if}}">
            <span class="stat-emoji">⚽</span>
            <span class="stat-value">{{this.goals}}</span>
          </span>
          <span class="match-detail-stat {{#if (gt this.assists 0)}}stat-active{{/if}}">
            <span class="stat-emoji">🎯</span>
            <span class="stat-value">{{this.assists}}</span>
          </span>
        </div>
      </div>
      {{/each}}
    </div>
  </div>

  <!-- Equipo Negro -->
  <div class="form-panel match-detail-team-panel">
    <div class="match-detail-team-header">
      <div class="match-detail-team-badge-lg">N</div>
      <span class="match-detail-team-label">Equipo Negro</span>
      <span class="match-detail-team-goals">{{totalGoalsB}} goles</span>
    </div>

    <div class="match-detail-players">
      {{#each teamBPlayers}}
      <div class="match-detail-player-row">
        <div class="match-detail-player-info">
          <span class="match-detail-player-name {{#if this.guest}}player-guest{{/if}}">
            {{this.player.name}}
            {{#if this.guest}}<span class="guest-tag">Invitado</span>{{/if}}
          </span>
        </div>
        <div class="match-detail-player-stats">
          <span class="match-detail-stat {{#if (gt this.goals 0)}}stat-active{{/if}}">
            <span class="stat-emoji">⚽</span>
            <span class="stat-value">{{this.goals}}</span>
          </span>
          <span class="match-detail-stat {{#if (gt this.assists 0)}}stat-active{{/if}}">
            <span class="stat-emoji">🎯</span>
            <span class="stat-value">{{this.assists}}</span>
          </span>
        </div>
      </div>
      {{/each}}
    </div>
  </div>

</div>

<!-- Moments -->
{{#if match.moments.length}}
<div class="form-panel match-detail-moments-panel">
  <p class="section-label">Momentos del Partido</p>
  <div class="match-detail-moments">
    {{#each match.moments}}
    <div class="match-detail-moment">
      <span class="match-detail-moment-minute">{{this.minute}}'</span>
      <span class="match-detail-moment-icon">
        {{#if (eq this.type "goal")}}⚽{{/if}}
        {{#if (eq this.type "assist")}}🎯{{/if}}
        {{#if (eq this.type "yellow")}}🟨{{/if}}
        {{#if (eq this.type "highlight")}}⭐{{/if}}
        {{#if (eq this.type "robot")}}🤖{{/if}}
      </span>
      <span class="match-detail-moment-type">{{this.type}}</span>
    </div>
    {{/each}}
  </div>
</div>
{{/if}}

<!-- Actions -->
<div class="match-detail-actions">
  <a href="/matches" class="btn-match-action">← Volver a partidos</a>
  {{#if (eq userRole "admin")}}
    <a href="/matches/{{match._id}}/edit" class="btn-match-action btn-edit">Editar</a>
  {{/if}}
  {{#if (eq userRole "superadmin")}}
    <a href="/matches/{{match._id}}/edit" class="btn-match-action btn-edit">Editar</a>
  {{/if}}
</div>