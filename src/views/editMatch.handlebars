<div class="page-header">
  <span class="eyebrow">Editar Partido</span>
  <h1>Modificar Resultado</h1>
</div>

<datalist id="playersList">
  {{#each players}}
    <option value="{{this.name}}">
  {{/each}}
</datalist>

<form action="/matches/{{match._id}}/edit?season={{season}}" method="POST">
  <div class="form-panel">
    <div class="form-row">
      <div>
        <p class="section-label">Fecha del partido</p>
        <input
          type="date"
          name="date"
          class="match-date-input"
          value="{{match.dateFormatted}}"
          required
        />
      </div>
      <div>
        <p class="section-label">Cancha</p>
        <input
          type="text"
          name="venue"
          class="match-venue-input"
          value="{{match.venue}}"
        />
      </div>
    </div>
    <div class="form-row">
      <div>
        <p class="section-label">YouTube</p>
        <input
          type="url"
          name="youtubeUrl"
          class="match-venue-input"
          value="{{match.youtubeUrl}}"
        />
      </div>
      <div>
        <p class="section-label">YouTube — Highlight</p>
        <input
          type="url"
          name="youtubeHlUrl"
          class="match-venue-input"
          value="{{match.youtubeHlUrl}}"
        />
      </div>
    </div>
  </div>

  <div class="form-panel">
    <p class="section-label">Resultado</p>
    <fieldset>
      <div class="score-inputs">
        <div class="score-team">
          <label>Blanco</label>
          <div class="match-score"><span
              id="scoreA"
            >{{match.teamA}}</span></div>
          <input
            type="hidden"
            name="teamA"
            id="teamA_score"
            value="{{match.teamA}}"
          />
        </div>
        <span class="score-vs">—</span>
        <div class="score-team">
          <label>Negro</label>
          <div class="match-score"><span
              id="scoreB"
            >{{match.teamB}}</span></div>
          <input
            type="hidden"
            name="teamB"
            id="teamB_score"
            value="{{match.teamB}}"
          />
        </div>
      </div>
    </fieldset>
  </div>

  <div class="teams-grid">
    <div class="form-panel">
      <p class="section-label">Equipo Blanco</p>
      <fieldset>
        <div id="teamA">
          {{#each match.players}}
            {{#if (eq this.team "A")}}
              <div class="player-row" data-existing="true">
                <span class="player-row-label">{{add @index 1}}</span>
                <input
                  type="text"
                  name="players[{{@index}}][name]"
                  value="{{this.player.name}}"
                  list="playersList"
                  autocomplete="off"
                />
                <span class="player-row-label">⚽</span>
                <input
                  type="number"
                  name="players[{{@index}}][goals]"
                  value="{{this.goals}}"
                  min="0"
                  oninput="updateScore()"
                />
                <span class="player-row-label">🎯</span>
                <input
                  type="number"
                  name="players[{{@index}}][assists]"
                  value="{{this.assists}}"
                  min="0"
                />
                <input
                  type="hidden"
                  name="players[{{@index}}][team]"
                  value="A"
                />
                <button
                  type="button"
                  class="btn-remove-player"
                  onclick="removePlayer(this)"
                >✕</button>
              </div>
            {{/if}}
          {{/each}}
        </div>
      </fieldset>
      <button type="button" class="btn-add-player" onclick="addPlayer('A')">+
        Agregar jugador</button>
    </div>

    <div class="form-panel">
      <p class="section-label">Equipo Negro</p>
      <fieldset>
        <div id="teamB">
          {{#each match.players}}
            {{#if (eq this.team "B")}}
              <div class="player-row" data-existing="true">
                <span class="player-row-label"></span>
                <input
                  type="text"
                  name="players[{{@index}}][name]"
                  value="{{this.player.name}}"
                  list="playersList"
                  autocomplete="off"
                />
                <span class="player-row-label">⚽</span>
                <input
                  type="number"
                  name="players[{{@index}}][goals]"
                  value="{{this.goals}}"
                  min="0"
                  oninput="updateScore()"
                />
                <span class="player-row-label">🎯</span>
                <input
                  type="number"
                  name="players[{{@index}}][assists]"
                  value="{{this.assists}}"
                  min="0"
                />
                <input
                  type="hidden"
                  name="players[{{@index}}][team]"
                  value="B"
                />
                <button
                  type="button"
                  class="btn-remove-player"
                  onclick="removePlayer(this)"
                >✕</button>
              </div>
            {{/if}}
          {{/each}}
        </div>
      </fieldset>
      <button type="button" class="btn-add-player" onclick="addPlayer('B')">+
        Agregar jugador</button>
    </div>
  </div>
  <div class="form-panel">
    <p class="section-label">Goles del partido</p>
    <div id="goal-timeline-list">
      {{#if match.goalTimeline.length}}
        {{#each match.goalTimeline}}
          <div class="player-row" draggable="true">
            <span class="drag-handle" title="Mover">⠿</span>
            <span class="player-row-label">{{add @index 1}}</span>
            <input type="text" name="goalTimeline[{{@index}}][scorer]"
              value="{{this.scorer}}" placeholder="Gol"
              list="playersList" autocomplete="off" />
            <span class="player-row-label">🎯</span>
            <input type="text" name="goalTimeline[{{@index}}][assist]"
              value="{{this.assist}}" placeholder="Asistencia (opcional)"
              list="playersList" autocomplete="off" />
            <button type="button" class="btn-og {{#if this.ownGoal}}btn-og-active{{/if}}" onclick="toggleOwnGoal(this)">EC</button>
            <input type="hidden" name="goalTimeline[{{@index}}][ownGoal]" value="{{#if this.ownGoal}}true{{else}}false{{/if}}" />
            <button type="button" class="btn-remove-player" onclick="removeGoalRow(this)">✕</button>
          </div>
        {{/each}}
      {{else}}
        <p class="empty-state" id="goals-empty">Sin goles cargados</p>
      {{/if}}
    </div>
    <button type="button" class="btn-add-player" onclick="addGoalRow()">
      + Agregar gol
    </button>
  </div>
  <button type="submit" class="btn-yellow">Guardar Cambios</button>
</form>

<script>
  window.index = {{match.players.length}};
  window.goalIndex = {{match.goalTimeline.length}};
</script>
<script src="/js/newMatch.js"></script>