<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Montserrat:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/img/favicon.png" />
    <link rel="stylesheet" href="/css/styles.css" />
    <title>Toskos FC</title>
  </head>
  <body>

    <nav class="nav-desktop">
      <a href="/">Inicio</a>
      <a href="/matches">Partidos</a>
      {{#if currentUser}}
        {{#if (eq currentUser.role "admin")}}
          <a href="/matches/new">Nuevo Partido</a>
        {{/if}}
        {{#if (eq currentUser.role "superadmin")}}
          <a href="/matches/new">Nuevo Partido</a>
        {{/if}}
      {{/if}}
      <a href="/stats">Estadísticas</a>
      <a href="/records">Récords</a>
      {{#if currentUser}}
      <div class="nav-search-wrap">
        <div class="nav-search-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
            <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
          </svg>
        </div>
        <input type="text" class="nav-search-input" id="playerSearchInput" placeholder="Buscar jugador..." autocomplete="off" />
        <div class="nav-search-dropdown" id="playerSearchDropdown"></div>
      </div>
      {{/if}}
      <div class="nav-auth">
        {{#if currentUser}}
          {{#if (eq currentUser.role "superadmin")}}
            <a href="/profile/admin/users" class="btn-nav-admin" title="Gestión de usuarios">⚙</a>
          {{/if}}
          <a href="/profile" class="nav-profile-link">
            {{#if currentUser.effectiveAvatar}}
              <img src="{{currentUser.effectiveAvatar}}" alt="avatar" class="nav-avatar" />
            {{else}}
              <div class="nav-avatar-placeholder">
                {{#if currentUser.displayName}}{{currentUser.displayName.[0]}}{{else}}{{currentUser.username.[0]}}{{/if}}
              </div>
            {{/if}}
            <span class="nav-username">{{#if currentUser.displayName}}{{currentUser.displayName}}{{else}}{{currentUser.username}}{{/if}}</span>
          </a>
          <form method="POST" action="/auth/logout" style="display:inline">
            <button type="submit" class="btn-nav-logout">Salir</button>
          </form>
        {{else}}
          <a href="/auth/login" class="btn-nav-login">Iniciar sesión</a>
        {{/if}}
      </div>
    </nav>

    <!-- Mobile Nav -->
    <nav class="nav-mobile">
      <a href="/" class="nav-mobile-brand">Toskos FC</a>
      {{#if currentUser}}
      <div class="nav-mobile-search-inline">
        <div class="nav-mobile-search-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
            <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
          </svg>
        </div>
        <input type="text" class="nav-mobile-search-input-inline" id="playerSearchInputMobile" placeholder="" autocomplete="off" />
        <div class="nav-mobile-search-dropdown" id="playerSearchDropdownMobile"></div>
      </div>
      {{/if}}
      <div class="nav-mobile-right">
        {{#if currentUser}}
        <a href="/profile" class="nav-mobile-profile">
          {{#if currentUser.effectiveAvatar}}
            <img src="{{currentUser.effectiveAvatar}}" alt="avatar" class="nav-mobile-avatar" />
          {{else}}
            <div class="nav-mobile-avatar-placeholder">
              {{#if currentUser.displayName}}{{currentUser.displayName.[0]}}{{else}}{{currentUser.username.[0]}}{{/if}}
            </div>
          {{/if}}
        </a>
        {{/if}}
        <button class="nav-hamburger" id="navHamburger" aria-label="Abrir menú">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>

    <!-- Mobile Menu Overlay -->
    <div class="nav-mobile-overlay" id="navMobileOverlay"></div>
    <div class="nav-mobile-menu" id="navMobileMenu">
      <div class="nav-mobile-header">
        <span class="nav-mobile-title">Menú</span>
        <div class="nav-mobile-header-right">
          {{#if currentUser}}
            {{#if (eq currentUser.role "superadmin")}}
              <a href="/profile/admin/users" class="nav-mobile-settings" title="Gestión de usuarios">
                <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                  <path d="M19.14 12.94c.04-.31.06-.64.06-.94 0-.31-.02-.63-.06-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.04.31-.06.63-.06.94s.02.63.06.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
                </svg>
              </a>
            {{/if}}
          {{/if}}
          <button class="nav-mobile-close" id="navMobileClose" aria-label="Cerrar menú">✕</button>
        </div>
      </div>
      <div class="nav-mobile-links">
        <a href="/">Inicio</a>
        <a href="/matches">Partidos</a>
        {{#if currentUser}}
          {{#if (eq currentUser.role "admin")}}
            <a href="/matches/new">Nuevo Partido</a>
          {{/if}}
          {{#if (eq currentUser.role "superadmin")}}
            <a href="/matches/new">Nuevo Partido</a>
          {{/if}}
        {{/if}}
        <a href="/stats">Estadísticas</a>
        <a href="/records">Récords</a>
        {{#if currentUser}}
        <form method="POST" action="/auth/logout">
          <button type="submit" class="nav-mobile-logout">Salir</button>
        </form>
        {{else}}
        <a href="/auth/login" class="nav-mobile-login">Iniciar sesión</a>
        {{/if}}
      </div>
    </div>

    <div class="page">
      {{{body}}}
    </div>

    <footer class="page-footer">
      <span>Toskos FC</span>
      <div class="footer-diamond"></div>
      <span>2017-2026</span>
    </footer>

    <div class="modal-overlay" id="deleteModal">
      <div class="modal">
        <p class="modal-title">¿Eliminar partido?</p>
        <p class="modal-desc">Esta acción no se puede deshacer.</p>
        <div class="modal-actions">
          <button class="btn-match-action" id="deleteCancelBtn">Cancelar</button>
          <form id="deleteForm" method="POST">
            <button type="submit" class="btn-match-action btn-delete">Eliminar</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Error modal -->
    <div class="modal-overlay" id="errorModal">
      <div class="modal modal-error">
        <div class="modal-error-icon">!</div>
        <p class="modal-title" id="errorModalMsg"></p>
        <div class="modal-actions" style="justify-content:center">
          <button type="button" id="errorModalBtn" class="btn-match-action btn-error-ok">Entendido</button>
        </div>
      </div>
    </div>

    <button class="btn-scroll-top" id="scrollTop">↑</button>

    <script src="/js/ui.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/realTime.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        var hamburger = document.getElementById('navHamburger');
        var overlay = document.getElementById('navMobileOverlay');
        var menu = document.getElementById('navMobileMenu');
        var closeBtn = document.getElementById('navMobileClose');

        function openMenu() {
          overlay.classList.add('active');
          menu.classList.add('active');
          document.body.style.overflow = 'hidden';
        }

        function closeMenu() {
          overlay.classList.remove('active');
          menu.classList.remove('active');
          document.body.style.overflow = '';
        }

        if (hamburger) hamburger.addEventListener('click', openMenu);
        if (overlay) overlay.addEventListener('click', closeMenu);
        if (closeBtn) closeBtn.addEventListener('click', closeMenu);

        // Mobile search functionality
        var mobileSearchInput = document.getElementById('playerSearchInputMobile');
        var mobileSearchDropdown = document.getElementById('playerSearchDropdownMobile');
        var mobileSearchTimeout;

        if (mobileSearchInput) {
          mobileSearchInput.addEventListener('input', function() {
            clearTimeout(mobileSearchTimeout);
            var q = this.value.trim();
            if (!q) {
              if (mobileSearchDropdown) mobileSearchDropdown.classList.remove('show');
              return;
            }
            mobileSearchTimeout = setTimeout(function() {
              fetch('/api/users/search?q=' + encodeURIComponent(q))
                .then(function(res) { return res.json(); })
                .then(function(users) {
                  if (!users.length) {
                    mobileSearchDropdown.innerHTML = '<div class="nav-search-no-results">No hay resultados</div>';
                  } else {
                    mobileSearchDropdown.innerHTML = users.slice(0, 8).map(function(u) {
                      var avatar = u.avatar
                        ? '<img src="' + u.avatar + '" class="nav-search-avatar" alt="" />'
                        : '<div class="nav-search-avatar-placeholder">' + (u.displayName || u.username || '?')[0] + '</div>';
                      return '<a href="/player/' + u._id + '" class="nav-search-item">' + avatar + '<span class="nav-search-name">' + (u.displayName || u.username) + '</span></a>';
                    }).join('');
                  }
                  mobileSearchDropdown.classList.add('show');
                });
            }, 200);
          });

          mobileSearchInput.addEventListener('blur', function() {
            setTimeout(function() {
              if (mobileSearchDropdown) mobileSearchDropdown.classList.remove('show');
            }, 200);
          });
        }
      });
    </script>
  </body>
</html>
