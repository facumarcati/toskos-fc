<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Montserrat:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/img/favicon.png" />

    <link rel="stylesheet" href="/css/styles.css" />
    <title>Toskos FC</title>
  </head>
  <body>

    <nav>
      <a href="/">Inicio</a>
      <a href="/matches">Partidos</a>
      <a href="/matches/new">Nuevo Partido</a>
      <a href="/stats">Estadísticas</a>
      <a href="/records">Récords</a>
      <div class="nav-auth">
        {{#if currentUser}}
          <a href="/profile" class="nav-profile-link">
            {{#if currentUser.avatar}}
              <img src="{{currentUser.avatar}}" alt="avatar" class="nav-avatar" />
            {{else}}
              <div class="nav-avatar-placeholder">
                {{#if currentUser.displayName}}{{currentUser.displayName.[0]}}{{else}}{{currentUser.username.[0]}}{{/if}}
              </div>
            {{/if}}
            <span class="nav-username">{{#if currentUser.displayName}}{{currentUser.displayName}}{{else}}{{currentUser.username}}{{/if}}</span>
          </a>
          <form method="POST" action="/auth/logout" style="display:inline">
            <button type="submit" class="btn-nav-logout">Salir</button>
          </form>
        {{else}}
          <a href="/auth/login" class="btn-nav-login">Iniciar sesión</a>
        {{/if}}
      </div>
    </nav>

    <div class="page">
      {{{body}}}
    </div>

    <footer class="page-footer">
      <span>Toskos FC</span>
      <div class="footer-diamond"></div>
      <span>2017-2026</span>
    </footer>

    <div class="modal-overlay" id="deleteModal">
      <div class="modal">
        <p class="modal-title">¿Eliminar partido?</p>
        <p class="modal-desc">Esta acción no se puede deshacer.</p>
        <div class="modal-actions">
          <button
            class="btn-match-action"
            onclick="closeDeleteModal()"
          >Cancelar</button>
          <form id="deleteForm" method="POST">
            <button
              type="submit"
              class="btn-match-action btn-delete"
            >Eliminar</button>
          </form>
        </div>
      </div>
    </div>

    <button
      class="btn-scroll-top"
      id="scrollTop"
      onclick="window.scrollTo({top:0,behavior:'smooth'})"
    >
      ↑
    </button>

    <script src="/js/ui.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/realTime.js"></script>
  </body>
</html>