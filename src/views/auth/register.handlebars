<div class="auth-card">
  <h1 class="auth-title">Crear cuenta</h1>

  {{#if error}}
    <p class="auth-error">{{error}}</p>
  {{/if}}

  <form class="auth-form" method="POST" action="/auth/register">

    <div class="form-group">
      <label for="firstName">Nombre</label>
      <input type="text" id="firstName" name="firstName" required maxlength="30"
        autocomplete="given-name" placeholder="Juan"
        value="{{formData.firstName}}" />
    </div>

    <div class="form-group">
      <label for="lastName">Apellido</label>
      <input type="text" id="lastName" name="lastName" required maxlength="30"
        autocomplete="family-name" placeholder="García"
        value="{{formData.lastName}}" />
    </div>

    <div class="form-group">
      <label for="birthDate">Fecha de nacimiento</label>
      <div class="birthdate-selectors">
        <select id="birthYear" name="birthYear" required class="birthdate-select">
          <option value="">Año</option>
        </select>
        <select id="birthMonth" name="birthMonth" required class="birthdate-select">
          <option value="">Mes</option>
          <option value="01">Enero</option>
          <option value="02">Febrero</option>
          <option value="03">Marzo</option>
          <option value="04">Abril</option>
          <option value="05">Mayo</option>
          <option value="06">Junio</option>
          <option value="07">Julio</option>
          <option value="08">Agosto</option>
          <option value="09">Septiembre</option>
          <option value="10">Octubre</option>
          <option value="11">Noviembre</option>
          <option value="12">Diciembre</option>
        </select>
        <select id="birthDay" name="birthDay" required class="birthdate-select">
          <option value="">Día</option>
        </select>
      </div>
      <input type="hidden" id="birthDate" name="birthDate" value="{{formData.birthDate}}" />
    </div>

    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required
        autocomplete="email" placeholder="tu@email.com"
        value="{{formData.email}}" />
    </div>

    <div class="form-group">
      <label for="password">Contraseña</label>
      <input type="password" id="password" name="password" required minlength="6"
        autocomplete="new-password" placeholder="Mínimo 6 caracteres" />
    </div>

    <div class="form-group">
      <label for="confirmPassword">Confirmar contraseña</label>
      <input type="password" id="confirmPassword" name="confirmPassword" required minlength="6"
        autocomplete="new-password" placeholder="Repetí tu contraseña" />
    </div>

    <button type="submit" class="btn-auth">Registrarse</button>
  </form>

  <script>
    (function() {
      var yearSelect = document.getElementById('birthYear');
      var monthSelect = document.getElementById('birthMonth');
      var daySelect = document.getElementById('birthDay');
      var hiddenInput = document.getElementById('birthDate');

      var currentYear = new Date().getFullYear();
      var startYear = currentYear - 100;
      var endYear = currentYear - 10;

      for (var y = endYear; y >= startYear; y--) {
        var opt = document.createElement('option');
        opt.value = y;
        opt.textContent = y;
        yearSelect.appendChild(opt);
      }

      function populateDays() {
        var year = parseInt(yearSelect.value);
        var month = parseInt(monthSelect.value);
        daySelect.innerHTML = '<option value="">Día</option>';
        if (!year || !month) return;

        var daysInMonth = new Date(year, month, 0).getDate();
        for (var d = 1; d <= daysInMonth; d++) {
          var opt = document.createElement('option');
          opt.value = d < 10 ? '0' + d : '' + d;
          opt.textContent = d;
          daySelect.appendChild(opt);
        }
      }

      function updateHidden() {
        var y = yearSelect.value;
        var m = monthSelect.value;
        var d = daySelect.value;
        if (y && m && d) {
          hiddenInput.value = y + '-' + m + '-' + d;
        } else {
          hiddenInput.value = '';
        }
      }

      yearSelect.addEventListener('change', function() {
        populateDays();
        updateHidden();
      });

      monthSelect.addEventListener('change', function() {
        populateDays();
        updateHidden();
      });

      daySelect.addEventListener('change', updateHidden);

      if (hiddenInput.value) {
        var parts = hiddenInput.value.split('-');
        if (parts.length === 3) {
          yearSelect.value = parts[0];
          monthSelect.value = parts[1];
          populateDays();
          daySelect.value = parts[2];
        }
      }
    })();
  </script>

  <div class="auth-divider"><span>o</span></div>

  <a href="/auth/google" class="btn-google">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="20" height="20">
      <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
      <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
      <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
      <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
    </svg>
    Registrarse con Google
  </a>

  <p class="auth-switch">
    ¿Ya tenés cuenta? <a href="/auth/login">Iniciá sesión</a>
  </p>
</div>
