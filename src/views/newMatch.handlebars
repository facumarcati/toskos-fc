<div class="page-header">
  <span class="eyebrow">Nuevo Partido</span>
  <h1>Cargar Resultado</h1>
</div>

<form action="/matches" method="POST">

  <div class="form-panel">
    <div class="form-row">
      <div>
        <p class="section-label">Fecha del partido</p>
        <input type="date" name="date" class="match-date-input" required />
      </div>
      <div>
        <p class="section-label">Cancha</p>
        <input
          type="text"
          name="venue"
          class="match-venue-input"
          value="{{match.venue}}"
        />
      </div>
    </div>
    <div class="form-row">
      <div>
        <p class="section-label">YouTube</p>
        <input
          type="url"
          name="youtubeUrl"
          class="match-venue-input"
          autocomplete="off"
        />
      </div>
      <div>
        <p class="section-label">YouTube — Highlight</p>
        <input type="url" name="youtubeHlUrl" class="match-venue-input" />
      </div>
    </div>
  </div>

  <div class="form-panel">
    <p class="section-label">Resultado</p>

    <fieldset>
      <div class="score-inputs">

        <div class="score-team">
          <label>Blanco</label>
          <div class="match-score">
            <span id="scoreA">0</span>
          </div>

          <input type="hidden" name="teamA" id="teamA_score" value="0" />
        </div>

        <span class="score-vs">—</span>

        <div class="score-team">
          <label>Negro</label>
          <div class="match-score">
            <span id="scoreB">0</span>
          </div>

          <input type="hidden" name="teamB" id="teamB_score" value="0" />
        </div>

      </div>
    </fieldset>
  </div>

  <!-- Equipos -->
  <div class="teams-grid">

    <div class="form-panel">
      <p class="section-label">Equipo Blanco</p>
      <fieldset>
        <div id="teamA">
          <p class="empty-state">Sin jugadores aún</p>
        </div>
      </fieldset>
      <button type="button" class="btn-add-player" onclick="addPlayer('A')">
        + Agregar jugador
      </button>
    </div>

    <div class="form-panel">
      <p class="section-label">Equipo Negro</p>
      <fieldset>
        <div id="teamB">
          <p class="empty-state">Sin jugadores aún</p>
        </div>
      </fieldset>
      <button type="button" class="btn-add-player" onclick="addPlayer('B')">
        + Agregar jugador
      </button>
    </div>

  </div>

  <button type="submit" class="btn-yellow">
    Guardar Partido
  </button>

</form>

<script src="/js/newMatch.js"></script>
<script src="/js/protectedRoute.js"></script>