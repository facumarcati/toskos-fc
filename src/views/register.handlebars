<div class="login-page">
  <div class="login-card">
    <div class="login-header">
      <h1 class="login-title">Toskos FC</h1>
      <p class="login-subtitle">Crear cuenta</p>
    </div>
    <form id="registerForm">
      <div class="login-field">
        <label class="login-label">Usuario</label>
        <input
          type="text"
          class="login-input"
          id="username"
          placeholder="Ingresa tu usuario"
          required
        />
      </div>
      <div class="login-field">
        <label class="login-label">Contraseña</label>
        <input
          type="password"
          class="login-input"
          id="password"
          placeholder="••••••••"
          required
        />
      </div>
      <div class="login-field">
        <label class="login-label">Soy el jugador</label>
        <select id="playerId" class="login-input" required>
          <option value="">Seleccionar jugador</option>
          {{#each players}}
            <option value="{{this._id}}">
              {{this.name}}
            </option>
          {{/each}}
        </select>
      </div>
      <p id="registerError" class="form-message"></p>
      <button
        type="submit"
        class="btn-yellow"
        style="width:100%; margin-top:8px;"
      >
        Crear cuenta
      </button>
    </form>
  </div>
</div>

<script src="/js/register.js"></script>