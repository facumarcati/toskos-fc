<div class="page-header">
  {{#if isViewingOther}}
  <span class="eyebrow">Perfil de usuario</span>
  <h1>{{#if viewedUser.displayName}}{{viewedUser.displayName}}{{else}}{{viewedUser.username}}{{/if}}</h1>
  <p class="page-header-meta">{{viewedUser.email}}</p>
  {{else}}
  <span class="eyebrow">Mi Cuenta</span>
  <h1>{{#if currentUser.displayName}}{{currentUser.displayName}}{{else}}{{currentUser.username}}{{/if}}</h1>
  <p class="page-header-meta">{{currentUser.email}}</p>
  {{/if}}
</div>

<div class="profile-grid">

  <!-- Avatar card -->
  <div class="form-panel profile-avatar-card">
    {{#if isViewingOther}}
    <p class="section-label">Foto de perfil</p>
    <div class="profile-avatar-wrap">
      {{#if viewedUser.effectiveAvatar}}
        <img src="{{viewedUser.effectiveAvatar}}" alt="avatar" class="profile-avatar-img" />
      {{else}}
        <div class="profile-avatar-placeholder">
          {{#if viewedUser.displayName}}{{viewedUser.displayName.[0]}}{{else}}{{viewedUser.username.[0]}}{{/if}}
        </div>
      {{/if}}
    </div>
    {{#if viewedUser.firstName}}
    <div style="margin-top:20px;width:100%;text-align:left">
      <p class="section-label">Datos personales</p>
      <p style="font-size:13px;color:var(--text-secondary)">{{viewedUser.firstName}} {{viewedUser.lastName}}</p>
      {{#if viewedUser.birthDate}}
        <p style="font-size:12px;color:var(--text-muted);margin-top:4px">{{formatDate viewedUser.birthDate}}</p>
      {{/if}}
    </div>
    {{/if}}
    {{else}}
    <p class="section-label">Foto de perfil</p>
    <div class="profile-avatar-wrap">
      {{#if currentUser.effectiveAvatar}}
        <img src="{{currentUser.effectiveAvatar}}" alt="avatar" class="profile-avatar-img" />
      {{else}}
        <div class="profile-avatar-placeholder">
          {{#if currentUser.displayName}}{{currentUser.displayName.[0]}}{{else}}{{currentUser.username.[0]}}{{/if}}
        </div>
      {{/if}}
    </div>

    <div class="avatar-upload-wrap">
      <button type="button" class="btn-upload-avatar" id="avatarPickerBtn">
        {{#if currentUser.avatar}}Cambiar foto{{else}}Subir foto{{/if}}
      </button>
      <input type="file" id="avatarFileInput" name="avatar" accept="image/jpeg,image/png,image/webp" class="avatar-file-input" />
    </div>
    <form action="/profile/avatar" method="POST" enctype="multipart/form-data" id="avatarForm" class="avatar-upload-form">
    {{#if currentUser.googleAvatar}}
      {{#unless currentUser.avatar}}
        <p style="font-size:11px;color:var(--text-muted);margin-top:8px;text-align:center">Usando foto de Google. Subí una propia para reemplazarla.</p>
      {{/unless}}
    {{/if}}
    </form>
    {{/if}}

    {{#if player}}
    <p class="section-label" style="margin-top:20px">Jugador vinculado</p>
    <p style="font-size:14px;font-weight:600;color:var(--accent)">{{player.name}}</p>
    {{/if}}

    {{#if currentUser.firstName}}
    {{#unless isViewingOther}}
    <div style="margin-top:20px;width:100%;text-align:left">
      <p class="section-label">Datos personales</p>
      <p style="font-size:13px;color:var(--text-secondary)">{{currentUser.firstName}} {{currentUser.lastName}}</p>
      {{#if currentUser.birthDate}}
        <p style="font-size:12px;color:var(--text-muted);margin-top:4px">{{formatDate currentUser.birthDate}}</p>
      {{/if}}
    </div>
    {{/unless}}
    {{/if}}
  </div>

  <!-- Winrate card -->
  <div class="form-panel profile-winrate-card">
    <p class="section-label">Winrate Histórico</p>
    <div class="profile-winrate-display">
      {{#if stats}}
        <span class="winrate-big">{{stats.winrate}}%</span>
      {{else}}
        <span class="winrate-big">—</span>
      {{/if}}
    </div>
    {{#if stats}}
    <p class="winrate-subtitle">{{stats.wins}} Victorias · {{stats.draws}} Empates · {{stats.losses}} Derrotas</p>
    {{/if}}
  </div>

  <!-- Stats & matches -->
  <div class="profile-stats-col">

    {{#if stats}}
    <div class="form-panel profile-stats-card">
      <p class="section-label">Estadísticas</p>
      <div class="profile-stats-grid">
        <div class="profile-stat-item">
          <span class="profile-stat-value">{{stats.matches}}</span>
          <span class="profile-stat-label">Partidos</span>
        </div>
        <div class="profile-stat-item">
          <span class="profile-stat-value cell-goals">{{stats.goals}}</span>
          <span class="profile-stat-label">Goles</span>
        </div>
        <div class="profile-stat-item">
          <span class="profile-stat-value cell-assists">{{stats.assists}}</span>
          <span class="profile-stat-label">Asistencias</span>
        </div>
        <div class="profile-stat-item">
          <span class="profile-stat-value cell-win">{{stats.wins}}</span>
          <span class="profile-stat-label">Victorias</span>
        </div>
        <div class="profile-stat-item">
          <span class="profile-stat-value cell-draw">{{stats.draws}}</span>
          <span class="profile-stat-label">Empates</span>
        </div>
        <div class="profile-stat-item">
          <span class="profile-stat-value cell-loss">{{stats.losses}}</span>
          <span class="profile-stat-label">Derrotas</span>
        </div>
        <div class="profile-stat-item">
          <span class="profile-stat-value cell-win">{{stats.winrate}}%</span>
          <span class="profile-stat-label">Winrate</span>
        </div>
      </div>
    </div>
    {{else}}
    <div class="form-panel">
      <p class="empty-state">Completá el onboarding para ver tus estadísticas.</p>
    </div>
    {{/if}}

    {{#if recentMatches.length}}
    <div class="form-panel profile-recent-matches">
      <p class="section-label">Últimos partidos</p>
      {{#each recentMatches}}
      <a href="/matches/{{this._id}}" class="profile-match-row">
        <div class="profile-match-info">
          <div class="profile-match-datetime">
            <span class="profile-match-date">{{formatDate this.date}}</span>
            {{#if this.venue}}
              <span class="profile-match-separator">·</span>
              <span class="profile-match-venue">{{this.venue}}</span>
            {{/if}}
          </div>
          <span class="profile-match-score">{{this.teamA}} — {{this.teamB}}</span>
        </div>
        <svg class="profile-match-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </a>
      {{/each}}
    </div>
    {{/if}}

  </div>
</div>

<script>
(function() {
  var pickerBtn = document.getElementById('avatarPickerBtn');
  var fileInput = document.getElementById('avatarFileInput');
  var form      = document.getElementById('avatarForm');

  if (!pickerBtn || !fileInput || !form) return;

  pickerBtn.addEventListener('click', function() {
    fileInput.click();
  });

  fileInput.addEventListener('change', function() {
    if (fileInput.files && fileInput.files.length > 0) {
      form.submit();
    }
  });
})();
</script>
