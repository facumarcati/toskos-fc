<div class="page-header">
  <a
    href="javascript:history.back()"
    class="eyebrow eyebrow-link"
    style="text-decoration: none;"
  >← Volver</a>
  <h1>{{#if
      profileUser.nickname
    }}{{profileUser.nickname}}{{else}}{{profileUser.username}}{{/if}}</h1>
  {{#if profileUser.nickname}}
    <p class="page-header-meta">@{{profileUser.username}}</p>
  {{/if}}
</div>

<div class="profile-card">
  <div class="profile-avatar">
    {{#if profileUser.avatarUrl}}
      <img
        src="{{profileUser.avatarUrl}}"
        alt="Avatar"
        class="profile-avatar-img"
      />
    {{else}}
      <div class="profile-avatar-placeholder">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="40"
          height="40"
          fill="currentColor"
        >
          <path
            d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v3h20v-3c0-3.3-6.7-5-10-5z"
          />
        </svg>
      </div>
    {{/if}}
  </div>

  <div class="profile-info">
    {{#if profileUser.bio}}
      <p class="profile-bio">{{profileUser.bio}}</p>
    {{else}}
      {{#if isOwner}}<p class="profile-bio profile-bio-empty">Sin descripción
          todavía.</p>{{/if}}
    {{/if}}

    {{#if profileUser.player}}
      <p class="profile-meta">
        Jugador vinculado:
        <span class="profile-player-name">{{profileUser.player.name}}</span>
      </p>
    {{/if}}

    <p class="profile-meta">Rol: {{profileUser.role}}</p>
  </div>
</div>

{{#if isOwner}}
  <div class="form-panel" style="margin-top: 24px;">
    <p class="section-label">Editar perfil</p>
    <form action="/profile/{{profileUser.username}}/edit" method="POST">
      <div class="form-row">
        <div>
          <p class="section-label">Apodo</p>
          <input
            type="text"
            name="nickname"
            class="match-venue-input"
            value="{{profileUser.nickname}}"
            placeholder="Tu apodo"
          />
        </div>
        <div>
          <p class="section-label">URL de avatar</p>
          <input
            type="url"
            name="avatarUrl"
            class="match-venue-input"
            value="{{profileUser.avatarUrl}}"
            placeholder="https://..."
          />
        </div>
      </div>
      <div style="margin-top: 12px;">
        <p class="section-label">Descripción</p>
        <textarea
          name="bio"
          class="match-venue-input"
          rows="3"
          placeholder="Nueve de área"
        >{{profileUser.bio}}</textarea>
      </div>
      <button
        type="submit"
        class="btn-yellow"
        style="margin-top: 16px;"
      >Guardar</button>
    </form>
  </div>
{{/if}}