{{#if topMVPs.length}}
<div class="records-section">
  <h2 class="record-title">Más veces MVP</h2>
  <div class="record-list">
    {{#each topMVPs}}
      <div class="record-card">
        <span class="record-pos record-pos-{{add @index 1}}">{{add @index 1}}°</span>
        <div class="record-info">
          <span class="record-name">{{this.name}}</span>
        </div>
        <div class="record-score">
          <span class="record-main">
            <svg viewBox="0 0 24 24" width="14" height="14" style="fill:var(--accent); vertical-align:middle; margin-right:4px;">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            {{this.mvps}}
          </span>
          <span class="record-meta">{{#if (eq this.mvps 1)}}vez{{else}}veces{{/if}}</span>
        </div>
      </div>
    {{/each}}
  </div>
</div>
{{/if}}