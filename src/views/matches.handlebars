<div class="page-header">
  <div class="page-header-top">
    <div>
      <span class="eyebrow">Historial</span>
      <h1>Partidos</h1>
      <p class="page-header-meta">
        {{matchCount}} {{#if (eq matchCount 1)}}partido{{else}}partidos{{/if}}
      </p>
    </div>
    {{#if matchCount}}
    <div class="match-donut-wrapper">
      <canvas id="matchDonut" width="110" height="110"></canvas>
      <div class="donut-legend">
        <span class="donut-legend-item"><span class="dot dot-white"></span>Blanco {{winsA}}</span>
        <span class="donut-legend-item"><span class="dot dot-draw"></span>Empate {{draws}}</span>
        <span class="donut-legend-item"><span class="dot dot-black"></span>Negro {{winsB}}</span>
        <div class="donut-goals">
          <span class="donut-goals-item"><span class="dot dot-white"></span>{{goalsA}} goles</span>
          <span class="donut-goals-item"><span class="dot dot-black"></span>{{goalsB}} goles</span>
        </div>
      </div>
    </div>
    {{/if}}
  </div>
</div>

<div class="matches-header">
  <div class="matches-filters">
    <form method="GET" action="/matches" class="season-filter">
      <input type="hidden" name="order" value="{{selectedOrder}}" />
      <input type="hidden" name="venue" value="{{selectedVenue}}" />
      <input type="hidden" name="date" value="{{selectedDate}}" />
      <select name="season" onchange="this.form.submit()">
        <option value="all" {{#if (eq selectedSeason "all")}}selected{{/if}}>Todas las temporadas</option>
        <option value="2026" {{#if (eq selectedSeason "2026")}}selected{{/if}}>2026</option>
        <option value="2025" {{#if (eq selectedSeason "2025")}}selected{{/if}}>2025</option>
        <option value="2024" {{#if (eq selectedSeason "2024")}}selected{{/if}}>2024</option>
      </select>
    </form>

    <form method="GET" action="/matches" class="season-filter">
      <input type="hidden" name="season" value="{{selectedSeason}}" />
      <input type="hidden" name="order" value="{{selectedOrder}}" />
      <input type="hidden" name="date" value="{{selectedDate}}" />
      <select name="venue" onchange="this.form.submit()">
        <option value="">Todas las canchas</option>
        {{#each venues}}
          <option value="{{this}}" {{#if (eq this ../selectedVenue)}}selected{{/if}}>{{this}}</option>
        {{/each}}
      </select>
    </form>

    <form method="GET" action="/matches" class="season-filter" style="display:flex; flex-direction: row; gap:6px; align-items:center;">
      <input type="hidden" name="season" value="{{selectedSeason}}" />
      <input type="hidden" name="order" value="{{selectedOrder}}" />
      <input type="hidden" name="venue" value="{{selectedVenue}}" />
      <input
        type="date"
        name="date"
        class="match-date-input-filter"
        value="{{selectedDate}}"
        style="padding: 7px 12px; font-size:12px; height:auto;"
      />
      <button type="submit" class="btn-order">→</button>
    </form>

    <form method="GET" action="/matches">
      <input type="hidden" name="season" value="{{selectedSeason}}" />
      <input type="hidden" name="venue" value="{{selectedVenue}}" />
      <input type="hidden" name="date" value="{{selectedDate}}" />
      <input type="hidden" name="order" value="{{#if (eq selectedOrder "asc")}}desc{{else}}asc{{/if}}" />
      <button type="submit" class="btn-order">
        {{#if (eq selectedOrder "asc")}}↑{{else}}↓{{/if}}
      </button>
    </form>

    {{#if (or selectedVenue selectedDate)}}
    <a href="/matches?season={{selectedSeason}}&order={{selectedOrder}}" class="btn-clear-filters">
      ✕ Limpiar
    </a>
    {{/if}}
  </div>

  <div class="matches-toolbar">
    <a href="/matches/new" class="btn-yellow btn-yellow-sm">+ Nuevo Partido</a>
  </div>
</div>

{{#each matches}}
<div class="match-card" id="match-{{this._id}}">
  <div class="match-scoreboard">
    <div class="match-team">
      <span class="match-team-label">Equipo</span>
      <span class="match-team-name">Blanco</span>
      {{#if (gt this.teamA this.teamB)}}
        <span class="match-badge badge-win">Ganador</span>
      {{else if (eq this.teamA this.teamB)}}
        <span class="match-badge badge-draw">Empate</span>
      {{/if}}
    </div>

    <div class="match-score">
      <div class="match-date">{{formatDate this.date}}</div>
      <span class="match-score-number">{{this.teamA}} — {{this.teamB}}</span>
      {{#if this.venue}}
        <span class="match-score-meta">{{this.venue}}</span>
      {{/if}}
    </div>

    <div class="match-team match-team-right">
      <span class="match-team-label">Equipo</span>
      <span class="match-team-name">Negro</span>
      {{#if (gt this.teamB this.teamA)}}
        <span class="match-badge badge-win">Ganador</span>
      {{else if (eq this.teamA this.teamB)}}
        <span class="match-badge badge-draw">Empate</span>
      {{/if}}
    </div>
  </div>

  <div class="match-players">
    <div class="match-team-col">
      <p class="section-label">Equipo Blanco</p>
      <ul class="player-list">
        {{#each this.players}}
          {{#if (eq this.team "A")}}
          <li class="player-item {{#if this.player.guest}}player-guest{{/if}}">
            <span class="player-item-name">{{this.player.name}}</span>
            <div class="player-item-stats">
              <span class="player-stat {{#if (gt this.goals 0)}}stat-active{{/if}}">
                ⚽ {{this.goals}}
              </span>
              <span class="player-stat {{#if (gt this.assists 0)}}stat-active{{/if}}">
                🎯 {{this.assists}}
              </span>
            </div>
          </li>
          {{/if}}
        {{/each}}
      </ul>
    </div>

    <div class="match-team-col">
      <p class="section-label">Equipo Negro</p>
      <ul class="player-list">
        {{#each this.players}}
          {{#if (eq this.team "B")}}
          <li class="player-item {{#if this.player.guest}}player-guest{{/if}}">
            <span class="player-item-name">{{this.player.name}}</span>
            <div class="player-item-stats">
              <span class="player-stat {{#if (gt this.goals 0)}}stat-active{{/if}}">
                ⚽ {{this.goals}}
              </span>
              <span class="player-stat {{#if (gt this.assists 0)}}stat-active{{/if}}">
                🎯 {{this.assists}}
              </span>
            </div>
          </li>
          {{/if}}
        {{/each}}
      </ul>
    </div>
  </div>

  <div class="match-card-footer">
    <div class="footer-left">
      {{#if this.youtubeUrl}}
      <a href="{{this.youtubeUrl}}" target="_blank" class="btn-youtube btn-youtube-full" title="Ver partido completo">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="#ff0000" xmlns="http://www.w3.org/2000/svg">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </a>
      {{/if}}
      {{#if this.youtubeHlUrl}}
      <a href="{{this.youtubeHlUrl}}" target="_blank" class="btn-youtube btn-youtube-hl" title="Ver highlight">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="#ffffff" xmlns="http://www.w3.org/2000/svg">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </a>
      {{/if}}
    </div>

    <div class="footer-right">
      <a href="/matches/{{this._id}}/edit?season={{../selectedSeason}}" class="btn-match-action btn-edit">Editar</a>
      <button type="button" class="btn-match-action btn-delete" onclick="openDeleteModal('/matches/{{this._id}}/delete')">Eliminar</button>
    </div>
  </div>
</div>
{{else}}
<div class="list-empty-state" style="text-align:center; padding:80px 20px">
  <p>No hay partidos todavía</p>
  <a href="/matches/new" class="btn-yellow" style="margin-top:24px; display:inline-flex; width:auto; padding:12px 32px">+ Nuevo Partido</a>
</div>
{{/each}}

<script src="/js/auth.js"></script>
<script>
  const donutData = { winsA: {{winsA}}, winsB: {{winsB}}, draws: {{draws}} };
</script>