<div class="page-header">
  <div class="page-header-top">
    <div>
      <span class="eyebrow">
        Historial
        {{#if (eq selectedSeason "all")}}
          - Todas las temporadas
        {{else}}
          {{selectedSeason}}
        {{/if}}
      </span>
      <h1>Partidos</h1>
      <p class="page-header-meta">
        {{matchCount}} {{#if (eq matchCount 1)}}partido{{else}}partidos{{/if}}
      </p>
    </div>
    {{#if matchCount}}
    <div class="match-donut-wrapper">
      <canvas id="matchDonut" width="110" height="110"></canvas>
      <div class="donut-legend">
        <span class="donut-legend-item"><span class="dot dot-white"></span>Blanco {{winsA}}</span>
        <span class="donut-legend-item"><span class="dot dot-draw"></span>Empate {{draws}}</span>
        <span class="donut-legend-item"><span class="dot dot-black"></span>Negro {{winsB}}</span>
        <div class="donut-goals">
          <span class="donut-goals-item"><span class="dot dot-white"></span>{{goalsA}} goles</span>
          <span class="donut-goals-item"><span class="dot dot-black"></span>{{goalsB}} goles</span>
        </div>
      </div>
    </div>
    {{/if}}
  </div>
</div>

<div class="matches-header">
  <div class="matches-filters">
    <form method="GET" action="/matches" class="season-filter">
      <input type="hidden" name="order" value="{{selectedOrder}}" />
      <input type="hidden" name="venue" value="{{selectedVenue}}" />
      <input type="hidden" name="date" value="{{selectedDate}}" />
      <select name="season" onchange="this.form.submit()">
        <option value="all" {{#if (eq selectedSeason "all")}}selected{{/if}}>Todas las temporadas</option>
        <option value="2026" {{#if (eq selectedSeason "2026")}}selected{{/if}}>2026</option>
        <option value="2025" {{#if (eq selectedSeason "2025")}}selected{{/if}}>2025</option>
        <option value="2024" {{#if (eq selectedSeason "2024")}}selected{{/if}}>2024</option>
      </select>
    </form>

    <form method="GET" action="/matches" class="season-filter">
      <input type="hidden" name="season" value="{{selectedSeason}}" />
      <input type="hidden" name="order" value="{{selectedOrder}}" />
      <input type="hidden" name="date" value="{{selectedDate}}" />
      <select name="venue" onchange="this.form.submit()">
        <option value="">Todas las canchas</option>
        {{#each venues}}
          <option value="{{this}}" {{#if (eq this ../selectedVenue)}}selected{{/if}}>{{this}}</option>
        {{/each}}
      </select>
    </form>

    <form method="GET" action="/matches" class="season-filter" style="display:flex; flex-direction: row; gap:6px; align-items:center;">
      <input type="hidden" name="season" value="{{selectedSeason}}" />
      <input type="hidden" name="order" value="{{selectedOrder}}" />
      <input type="hidden" name="venue" value="{{selectedVenue}}" />
      <input
        type="date"
        name="date"
        class="match-date-input-filter"
        value="{{selectedDate}}"
        style="padding: 7px 12px; font-size:12px; height:auto;"
      />
      <button type="submit" class="btn-order">→</button>
    </form>

    <form method="GET" action="/matches">
      <input type="hidden" name="season" value="{{selectedSeason}}" />
      <input type="hidden" name="venue" value="{{selectedVenue}}" />
      <input type="hidden" name="date" value="{{selectedDate}}" />
      <input type="hidden" name="order" value="{{#if (eq selectedOrder "asc")}}desc{{else}}asc{{/if}}" />
      <button type="submit" class="btn-order">
        {{#if (eq selectedOrder "asc")}}↑{{else}}↓{{/if}}
      </button>
    </form>

    {{#if (or selectedVenue selectedDate)}}
    <a href="/matches?season={{selectedSeason}}&order={{selectedOrder}}" class="btn-clear-filters">
      ✕ Limpiar
    </a>
    {{/if}}
  </div>

  <div class="matches-toolbar">
    <a href="/matches/new" class="btn-yellow btn-yellow-sm">+ Nuevo Partido</a>
  </div>
</div>

{{#each matches}}
<div class="match-card" id="match-{{this._id}}">
  <div class="match-scoreboard
  {{#if (gt this.teamA this.teamB)}}scoreboard-win-a
  {{else if (gt this.teamB this.teamA)}}scoreboard-win-b
  {{else}}scoreboard-draw
  {{/if}}">
    <div class="match-team">
      <span class="match-team-label">Equipo</span>
      <span class="match-team-name">Blanco</span>
    </div>

    <div class="match-score">
      <div class="match-date">{{formatDate this.date}} · {{this.venue}}</div>
      <span class="match-score-number">{{this.teamA}} — {{this.teamB}}</span>
    </div>

    <div class="match-team match-team-right">
      <span class="match-team-label">Equipo</span>
      <span class="match-team-name">Negro</span>
    </div>
  </div>

  <div class="match-players">
    <div class="match-team-col">
      <div class="player-list-header">
        <span class="player-list-header-name">Jugador</span>
        <div class="player-list-header-stats">
          <span>G</span>
          <span>A</span>
        </div>
      </div>
      <ul class="player-list">
        {{#each this.players}}
          {{#if (eq this.team "A")}}
          <li class="player-item 
                {{#if this.player.guest}}player-guest{{/if}}
                {{#if (includes ../mvpPlayers this.player._id)}}player-mvp{{/if}}"
            {{#if @root.user}}
              onclick="voteMVP('{{../_id}}','{{this.player._id}}')"
            {{else}}
              title="Logueate para votar"
              style="cursor: default;"
            {{/if}}>
            <span class="player-item-name">
              {{this.player.name}}
              {{#if (gt (getVoteCount ../voteCountByPlayer this.player._id) 0)}}
                <span class="mvp-badge {{#if (includes ../mvpPlayers this.player._id)}}mvp-badge-leader{{/if}}">
                  {{#if (includes ../mvpPlayers this.player._id)}}
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {{/if}}
                  {{getVoteCount ../voteCountByPlayer this.player._id}}
                </span>
              {{/if}}
            </span>
            <div class="player-item-stats">
              <span class="player-stat {{#if (gt this.goals 0)}}stat-active{{/if}}">
                {{this.goals}}
              </span>
              <span class="player-stat {{#if (gt this.assists 0)}}stat-active{{/if}}">
                {{this.assists}}
              </span>
            </div>
          </li>
          {{/if}}
        {{/each}}
      </ul>
    </div>

    <div class="match-team-col">
      <div class="player-list-header">
        <span class="player-list-header-name">Jugador</span>
        <div class="player-list-header-stats">
          <span>G</span>
          <span>A</span>
        </div>
      </div>
      <ul class="player-list">
        {{#each this.players}}
          {{#if (eq this.team "B")}}
          <li class="player-item 
                {{#if this.player.guest}}player-guest{{/if}}
                {{#if (includes ../mvpPlayers this.player._id)}}player-mvp{{/if}}"
          {{#if @root.user}}
            onclick="voteMVP('{{../_id}}','{{this.player._id}}')"
          {{else}}
            title="Logueate para votar"
            style="cursor: default;"
          {{/if}}>
          <span class="player-item-name">
            {{this.player.name}}
            {{#if (gt (getVoteCount ../voteCountByPlayer this.player._id) 0)}}
              <span class="mvp-badge {{#if (includes ../mvpPlayers this.player._id)}}mvp-badge-leader{{/if}}">
                {{#if (includes ../mvpPlayers this.player._id)}}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {{/if}}
                {{getVoteCount ../voteCountByPlayer this.player._id}}
              </span>
            {{/if}}
          </span>
          <div class="player-item-stats">
            <span class="player-stat {{#if (gt this.goals 0)}}stat-active{{/if}}">
              {{this.goals}}
            </span>
            <span class="player-stat {{#if (gt this.assists 0)}}stat-active{{/if}}">
              {{this.assists}}
            </span>
          </div>
          </li>
          {{/if}}
        {{/each}}
      </ul>
    </div>
  </div>

  <div class="match-card-footer">
    <div class="footer-left">
      {{#if this.youtubeUrl}}
      <a href="{{this.youtubeUrl}}" target="_blank" class="btn-youtube btn-youtube-full" title="Ver partido completo">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="#ff0000" xmlns="http://www.w3.org/2000/svg">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </a>
      {{/if}}
      {{#if this.youtubeHlUrl}}
      <a href="{{this.youtubeHlUrl}}" target="_blank" class="btn-youtube btn-youtube-hl" title="Ver highlight">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="#ffffff" xmlns="http://www.w3.org/2000/svg">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </a>
      {{/if}}
    </div>

    <div class="footer-right">
      <button 
        type="button" 
        class="btn-match-action btn-copy"
        onclick="copyMatch('{{this._id}}', event)"
        title="Copiar imagen">
        <svg viewBox="0 0 24 24" width="16" height="16">
          <path d="M16 1H4C2.9 1 2 1.9 2 3v12h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/>
        </svg>
      </button>
      <a href="/matches/{{this._id}}" class="btn-match-action" title="Ver detalle">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="white">
          <path d="M12 5c-7 0-10 7-10 7s3 7 10 7 10-7 10-7-3-7-10-7zm0 12a5 5 0 1 1 0-10 5 5 0 0 1 0 10zm0-8a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/>
        </svg>
      </a>
      {{#if (and @root.user (eq @root.user.role "admin"))}}
        <a href="/matches/{{this._id}}/edit?season={{../selectedSeason}}" 
          class="btn-match-action btn-edit" 
          title="Editar">
          <svg viewBox="0 0 24 24" width="16" height="16">
            <path d="M3 17.25V21h3.75L19.81 7.94l-3.75-3.75L3 17.25zm2.92 2.33H5v-.92l9.06-9.06.92.92L5.92 19.58zM20.71 6.04a1 1 0 0 0 0-1.41l-1.34-1.34a1 1 0 0 0-1.41 0l-1.13 1.13 2.75 2.75 1.13-1.13z"/>
          </svg>
        </a>
        <button type="button" 
                class="btn-match-action btn-delete" 
                onclick="openDeleteModal('/matches/{{this._id}}/delete')" 
                title="Eliminar">
          <svg viewBox="0 0 448 512" width="16" height="16">
            <path d="M135.2 17.7L128 32H32C14.3 32 0 46.3 0 64S14.3 96 32 96H416c17.7 0 32-14.3 32-32s-14.3-32-32-32H320l-7.2-14.3C307.4 6.8 296.3 0 284.2 0H163.8c-12.1 0-23.2 6.8-28.6 17.7zM416 128H32L53.2 467c1.6 25.3 22.6 45 47.9 45H346.9c25.3 0 46.3-19.7 47.9-45L416 128z"/>
          </svg> 
        </button>
      {{/if}}
    </div>
  </div>
</div>
{{else}}
<div class="list-empty-state" style="text-align:center; padding:80px 20px">
  <p>No hay partidos todavía</p>
  <a href="/matches/new" class="btn-yellow" style="margin-top:24px; display:inline-flex; width:auto; padding:12px 32px">+ Nuevo Partido</a>
</div>
{{/each}}

<script src="/js/auth.js"></script>
<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
<script>
  const donutData = { winsA: {{winsA}}, winsB: {{winsB}}, draws: {{draws}} };
</script>
<script>
async function voteMVP(matchId, playerId) {
  try {
    await fetch(`/matches/${matchId}/vote-mvp`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ playerId })
    });
    location.reload();
  } catch(err) {
    console.error(err);
  }
}
</script>
<script>
async function copyMatch(matchId) {
  const element = document.getElementById(`match-${matchId}`);

  const footer = element.querySelector(".match-card-footer");
  footer.style.display = "none";

  const canvas = await html2canvas(element, {
    scale: 2,
    useCORS: true
  });

  footer.style.display = "flex";

  canvas.toBlob(async (blob) => {
    try {
      await navigator.clipboard.write([
        new ClipboardItem({
          "image/png": blob
        })
      ]);

      showToast("✓ Imagen copiada", "success");
    } catch (err) {
      console.error(err);

      showToast("No se pudo copiar la imagen", "error");
    }
  });
}
</script>