<div class="page-header">
  <span class="eyebrow">Historial</span>
  <h1>Partidos</h1>
  <p class="page-header-meta">
    {{matchCount}} {{#if (eq matchCount 1)}}partido{{else}}partidos{{/if}}
  </p>
</div>

<div class="matches-header">
  <form method="GET" action="/matches" class="season-filter">
    <select name="season" onchange="this.form.submit()">
      <option value="all" {{#if (eq selectedSeason "all")}}selected{{/if}}>
        Todas las temporadas
      </option>
      <option value="2026" {{#if (eq selectedSeason "2026")}}selected{{/if}}>
        2026
      </option>
      <option value="2025" {{#if (eq selectedSeason "2025")}}selected{{/if}}>
        2025
      </option>
      <option value="2024" {{#if (eq selectedSeason "2024")}}selected{{/if}}>
        2024
      </option>
    </select>
  </form>

  <div class="matches-toolbar">
    <a href="/matches/new" class="btn-yellow btn-yellow-sm">+ Nuevo Partido</a>
  </div>
</div>

{{#each matches}}
<div class="match-card">

  <!-- Scoreboard -->
  <div class="match-scoreboard">
    <div class="match-team">
      <span class="match-team-label">Equipo</span>
      <span class="match-team-name">Blanco</span>
      {{#if (gt this.teamA this.teamB)}}
        <span class="match-badge badge-win">Ganador</span>
      {{else if (eq this.teamA this.teamB)}}
        <span class="match-badge badge-draw">Empate</span>
      {{/if}}
    </div>

    <div class="match-score">
      <div class="match-date">
        {{formatDate this.date}}
      </div>
      <span class="match-score-number">{{this.teamA}} — {{this.teamB}}</span>
      <span class="match-score-meta">{{this.players.length}} jugadores</span>
    </div>

    <div class="match-team match-team-right">
      <span class="match-team-label">Equipo</span>
      <span class="match-team-name">Negro</span>
      {{#if (gt this.teamB this.teamA)}}
        <span class="match-badge badge-win">Ganador</span>
      {{else if (eq this.teamA this.teamB)}}
        <span class="match-badge badge-draw">Empate</span>
      {{/if}}
    </div>
  </div>

  <!-- Players -->
  <div class="match-players">
    <div class="match-team-col">
      <p class="section-label">Equipo Blanco</p>
      <ul class="player-list">
        {{#each this.players}}
          {{#if (eq this.team "A")}}
          <li class="player-item {{#if this.guest}}player-guest{{/if}}">
            <span class="player-item-name">{{this.player.name}}</span>
            <div class="player-item-stats">
              <span class="player-stat {{#if (gt this.goals 0)}}stat-active{{/if}}">
                ⚽ {{this.goals}}
              </span>
              <span class="player-stat {{#if (gt this.assists 0)}}stat-active{{/if}}">
                🎯 {{this.assists}}
              </span>
            </div>
          </li>
          {{/if}}
        {{/each}}
      </ul>
    </div>

    <div class="match-team-col">
      <p class="section-label">Equipo Negro</p>
      <ul class="player-list">
        {{#each this.players}}
          {{#if (eq this.team "B")}}
          <li class="player-item {{#if this.guest}}player-guest{{/if}}">
            <span class="player-item-name">{{this.player.name}}</span>
            <div class="player-item-stats">
              <span class="player-stat {{#if (gt this.goals 0)}}stat-active{{/if}}">
                ⚽ {{this.goals}}
              </span>
              <span class="player-stat {{#if (gt this.assists 0)}}stat-active{{/if}}">
                🎯 {{this.assists}}
              </span>
            </div>
          </li>
          {{/if}}
        {{/each}}
      </ul>
    </div>
  </div>

  <div class="match-card-footer">
    <a href="/matches/{{this._id}}/edit" class="btn-match-action btn-edit">
      Editar
    </a>
    <button
      type="button"
      class="btn-match-action btn-delete"
      onclick="openDeleteModal('/matches/{{this._id}}/delete')"
    >
      Eliminar
    </button>
  </div>

</div>
{{else}}
<div class="list-empty-state" style="text-align:center; padding:80px 20px">
  <p>No hay partidos todavía</p>
  <a href="/matches/new" class="btn-yellow" style="margin-top:24px; display:inline-flex; width:auto; padding:12px 32px">+ Nuevo Partido</a>
</div>
{{/each}}