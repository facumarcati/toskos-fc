<div class="page-header">
  <div class="page-header-top">
    <div>
      <a href="javascript:history.back()" class="eyebrow eyebrow-link" style="text-decoration: none;">
        ← Partidos
      </a>
      <h1>Detalle del Partido</h1>
    </div>
  </div>
</div>

{{!-- Scoreboard --}}
<div class="match-card">
  <div class="match-scoreboard
    {{#if (gt match.teamA match.teamB)}}scoreboard-win-a
    {{else if (gt match.teamB match.teamA)}}scoreboard-win-b
    {{else}}scoreboard-draw
    {{/if}}">
    <div class="match-team">
      <span class="match-team-label">Equipo</span>
      <span class="match-team-name">Blanco</span>
    </div>
    <div class="match-score">
      <div class="match-date">{{formatDate match.date}} · {{match.venue}}</div>
      <span class="match-score-number">{{match.teamA}} — {{match.teamB}}</span>
    </div>
    <div class="match-team match-team-right">
      <span class="match-team-label">Equipo</span>
      <span class="match-team-name">Negro</span>
    </div>
  </div>

  <div class="match-players">
    <div class="match-team-col">
      <div class="player-list-header">
        <span class="player-list-header-name">Jugador</span>
        <div class="player-list-header-stats">
          <span>G</span>
          <span>A</span>
        </div>
      </div>
      <ul class="player-list">
        {{#each match.players}}
          {{#if (eq this.team "A")}}
            <li class="player-item
              {{#if this.player.guest}}player-guest{{/if}}
              {{#if (includes ../match.mvpPlayers this.player._id)}}player-mvp{{/if}}"
              {{#if @root.user}}
                onclick="voteMVP('{{../match._id}}','{{this.player._id}}')"
              {{else}}
                title="Logueate para votar"
                style="cursor: default;"
              {{/if}}>
              <span class="player-item-name">
                {{this.player.name}}
                {{#if (gt (getVoteCount ../match.voteCountByPlayer this.player._id) 0)}}
                  <span class="mvp-badge {{#if (includes ../match.mvpPlayers this.player._id)}}mvp-badge-leader{{/if}}">
                    {{#if (includes ../match.mvpPlayers this.player._id)}}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    {{/if}}
                    {{getVoteCount ../match.voteCountByPlayer this.player._id}}
                  </span>
                {{/if}}
              </span>
              <div class="player-item-stats">
                <span class="player-stat {{#if (gt this.goals 0)}}stat-active{{/if}}">{{this.goals}}</span>
                <span class="player-stat {{#if (gt this.assists 0)}}stat-active{{/if}}">{{this.assists}}</span>
              </div>
            </li>
          {{/if}}
        {{/each}}
      </ul>
    </div>

    <div class="match-team-col">
      <div class="player-list-header">
        <span class="player-list-header-name">Jugador</span>
        <div class="player-list-header-stats">
          <span>G</span>
          <span>A</span>
        </div>
      </div>
      <ul class="player-list">
        {{#each match.players}}
          {{#if (eq this.team "B")}}
            <li class="player-item
              {{#if this.player.guest}}player-guest{{/if}}
              {{#if (includes ../match.mvpPlayers this.player._id)}}player-mvp{{/if}}"
              {{#if @root.user}}
                onclick="voteMVP('{{../match._id}}','{{this.player._id}}')"
              {{else}}
                title="Logueate para votar"
                style="cursor: default;"
              {{/if}}>
              <span class="player-item-name">
                {{this.player.name}}
                {{#if (gt (getVoteCount ../match.voteCountByPlayer this.player._id) 0)}}
                  <span class="mvp-badge {{#if (includes ../match.mvpPlayers this.player._id)}}mvp-badge-leader{{/if}}">
                    {{#if (includes ../match.mvpPlayers this.player._id)}}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    {{/if}}
                    {{getVoteCount ../match.voteCountByPlayer this.player._id}}
                  </span>
                {{/if}}
              </span>
              <div class="player-item-stats">
                <span class="player-stat {{#if (gt this.goals 0)}}stat-active{{/if}}">{{this.goals}}</span>
                <span class="player-stat {{#if (gt this.assists 0)}}stat-active{{/if}}">{{this.assists}}</span>
              </div>
            </li>
          {{/if}}
        {{/each}}
      </ul>
    </div>
  </div>

  <div class="match-card-footer">
    <div class="footer-left">
      {{#if match.youtubeUrl}}
        <a href="{{match.youtubeUrl}}" target="_blank" class="btn-youtube btn-youtube-full" title="Ver partido completo">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#ff0000"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      {{/if}}
      {{#if match.youtubeHlUrl}}
        <a href="{{match.youtubeHlUrl}}" target="_blank" class="btn-youtube btn-youtube-hl" title="Ver highlight">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#ffffff"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      {{/if}}
    </div>
    <div class="footer-right">
      <button 
        type="button" 
        class="btn-match-action btn-copy"
        onclick="copyMatch('{{this._id}}', event)"
        title="Copiar imagen">
        <svg viewBox="0 0 24 24" width="16" height="16">
          <path d="M16 1H4C2.9 1 2 1.9 2 3v12h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/>
        </svg>
      </button>
      {{#if (and user (eq user.role "admin"))}}
        <a href="/matches/{{match._id}}/edit" class="btn-match-action btn-edit">Editar</a>
      {{/if}}
    </div>
  </div>
</div>

{{!-- Timeline de goles --}}
{{#if match.goalTimelineProcessed.length}}
<div class="form-panel">
  <p class="section-label" style="text-align: center; font-size: 13px">Goles del partido</p>
  <div class="goal-timeline-vertical">
    {{#each match.goalTimelineProcessed}}
      <div class="gtv-row gtv-row-{{this.side}}">
        <div class="gtv-cell gtv-left">
          {{#if (eq this.side "left")}}
            <span class="gtv-scorer">
              {{this.scorer}}{{#if this.isOwnGoal}} <span class="gtv-og">(EC)</span>{{/if}}
            </span>
            {{#if this.assist}}<span class="gtv-assist">asist. {{this.assist}}</span>{{/if}}
          {{/if}}
        </div>
        <div class="gtv-center">
          <span class="gtv-score">{{this.scoreA}}–{{this.scoreB}}</span>
        </div>
        <div class="gtv-cell gtv-right">
          {{#if (eq this.side "right")}}
            <span class="gtv-scorer">
              {{this.scorer}}{{#if this.isOwnGoal}} <span class="gtv-og">(EC)</span>{{/if}}
            </span>
            {{#if this.assist}}<span class="gtv-assist">asist. {{this.assist}}</span>{{/if}}
          {{/if}}
        </div>
      </div>
    {{/each}}
  </div>
</div>
{{/if}}

<script src="/js/auth.js"></script>
<script>
async function voteMVP(matchId, playerId) {
  try {
    await fetch(`/matches/${matchId}/vote-mvp`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ playerId })
    });
    location.reload();
  } catch(err) {
    console.error(err);
  }
}
</script>
<script>
async function copyMatch(matchId) {
  const element = document.getElementById(`match-${matchId}`);

  const footer = element.querySelector(".match-card-footer");
  footer.style.display = "none";

  const canvas = await html2canvas(element, {
    scale: 2,
    useCORS: true
  });

  footer.style.display = "flex";

  canvas.toBlob(async (blob) => {
    try {
      await navigator.clipboard.write([
        new ClipboardItem({
          "image/png": blob
        })
      ]);

      showToast("✓ Imagen copiada", "success");
    } catch (err) {
      console.error(err);

      showToast("No se pudo copiar la imagen", "error");
    }
  });
}
</script>