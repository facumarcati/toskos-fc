<div class="page-header">
  <span class="eyebrow">
  {{#if (eq selectedSeason "all")}}
    Todas las temporadas
  {{else}}
    Temporada {{selectedSeason}}
  {{/if}}
</span>
  <h1>Estadísticas</h1>
</div>

<div class="matches-header">
  <div style="display:flex; gap:8px; align-items:center;">
    <form method="GET" action="/stats" class="season-filter">
      {{#if includeGuests}}<input type="hidden" name="guests" value="1" />{{/if}}
      <input type="hidden" name="sortBy" value="{{selectedSort}}" />
      <input type="hidden" name="orderDir" value="{{selectedOrderDir}}" />
      <select name="season" onchange="this.form.submit()">
        <option value="all" {{#if (eq selectedSeason "all")}}selected{{/if}}>Todas las temporadas</option>
            <option value="2026" {{#if (eq selectedSeason "2026")}}selected{{/if}}>2026</option>
            <option value="2025" {{#if (eq selectedSeason "2025")}}selected{{/if}}>2025</option>
            <option value="2024" {{#if (eq selectedSeason "2024")}}selected{{/if}}>2024</option>
      </select>
    </form>

    <form method="GET" action="/stats" class="season-filter">
      <input type="hidden" name="season" value="{{selectedSeason}}" />
      {{#if includeGuests}}<input type="hidden" name="guests" value="1" />{{/if}}
      <input type="hidden" name="orderDir" value="{{selectedOrderDir}}" />
      <select name="sortBy" onchange="this.form.submit()">
        <option value="goals"   {{#if (eq selectedSort "goals")}}selected{{/if}}>Goles</option>
        <option value="assists" {{#if (eq selectedSort "assists")}}selected{{/if}}>Asistencias</option>
        <option value="wins"    {{#if (eq selectedSort "wins")}}selected{{/if}}>Victorias</option>
        <option value="matches" {{#if (eq selectedSort "matches")}}selected{{/if}}>Partidos</option>
      </select>
    </form>
  </div>

  <form method="GET" action="/stats" class="season-filter">
    <input type="hidden" name="season" value="{{selectedSeason}}" />
    <input type="hidden" name="sortBy" value="{{selectedSort}}" />
    <input type="hidden" name="orderDir" value="{{selectedOrderDir}}" />
    <label class="filter-checkbox">
      <input
        type="checkbox"
        id="toggleGuests"
        name="guests"
        value="1"
        {{#if includeGuests}}checked{{/if}}
        onchange="this.form.submit()"
      />
      Incluir invitados
    </label>
  </form>
</div>

<div id="stats-table">
  <div class="product-list-section">

    <div class="product-list-header">
      <span class="col-num">#</span>
      <span>Jugador</span>
      <span style="text-align:center">PJ</span>
      <span style="text-align:center">PG</span>
      <span style="text-align:center">PE</span>
      <span style="text-align:center">PP</span>
      <span style="text-align:center">G</span>
      <span style="text-align:center">A</span>
    </div>

    <ul class="product-list">
      {{#each stats}}
        <li class="product-row stat-row {{#if this.isGuest}}player-guest{{/if}}"
          {{#unless (isEC this.name)}}
            style="cursor: pointer;"
            onclick="window.location='/players/{{this._id}}?season={{../selectedSeason}}'"
          {{/unless}}
        >
          <span class="col-num">{{add @index 1}}</span>
          <div class="col-title">
            <a class="product-row-title">
              {{this.name}}
              {{#if this.titles}}
                <span class="player-titles">
                  🏆 {{this.titles}}
                </span>
              {{/if}}
            </a>
          </div>

          <span class="stat-cell">
            {{#if (isEC this.name)}}-{{else}}{{this.matches}}{{/if}}
          </span>

          <span class="stat-cell cell-win">
            {{#if (isEC this.name)}}-{{else}}{{this.wins}}{{/if}}
          </span>

          <span class="stat-cell cell-draw">
            {{#if (isEC this.name)}}-{{else}}{{this.draws}}{{/if}}
          </span>

          <span class="stat-cell cell-loss">
            {{#if (isEC this.name)}}-{{else}}{{this.losses}}{{/if}}
          </span>

          <span class="stat-cell cell-goals">
            {{this.goals}}
          </span>

          <span class="stat-cell cell-assists">
            {{#if (isEC this.name)}}-{{else}}{{this.assists}}{{/if}}
          </span>
        </li>

      {{else}}
        <li class="list-empty-state">Sin estadísticas todavía</li>
      {{/each}}
    </ul>
  </div>
</div>

<div class="stats-criteria">
  <p class="stats-criteria-title">Criterios de desempate</p>
  <ul class="stats-criteria-list">
    <li><span class="criteria-label">Goles:</span> Goles → Asistencias → Menos partidos</li>
    <li><span class="criteria-label">Asistencias:</span> Asistencias → Goles → Menos partidos</li>
    <li><span class="criteria-label">Victorias:</span> Victorias → Menos partidos → Goles → Asistencias</li>
    <li><span class="criteria-label">Partidos:</span> Partidos → Victorias → Goles → Asistencias</li>
  </ul>
</div>

<script src="/js/stats.js"></script>
<script src="/js/titles.js"></script>